# ==============================================================
# CONFIGURAÇÕES OBRIGATÓRIAS - SimuladorHNT
# Copie este arquivo para .env e preencha os valores reais
# NUNCA envie o .env para o GitHub!
# ==============================================================

# --- Supabase ---
# URL do seu projeto (visível no painel Supabase > Settings > API)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Service Role Key (SECRETA - em Settings > API, nunca expor no front-end)
SUPABASE_SERVICE_KEY=SEU_SERVICE_ROLE_KEY_AQUI

# --- Autenticação Admin ---
# Gere uma chave forte com: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=GERE_UMA_CHAVE_LONGA_E_ALEATORIA_AQUI

# Usuário/senha de acesso administrativo
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SUA_SENHA_FORTE_AQUI

# --- Servidor ---
PORT=3000
